{
  "name": "ebkcr",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "tsr generate && tsc --noEmit && vite build",
    "check": "oxfmt --check && oxlint",
    "dev": "vite dev --host --port 3000",
    "fetch-data": "tsx --env-file-if-exists=.env scripts/fetch-data.ts",
    "fix": "oxlint --fix && oxfmt .",
    "format": "oxfmt .",
    "lint": "oxlint",
    "preview": "vite preview",
    "typecheck": "tsr generate && tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=22.10.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
