# Copy to .env and fill in for local data fetches: `cp .env.example .env`
# Get a token at https://developer.clashroyale.com/ (see README).

# Your Clash Royale API token (Bearer JWT).
# NOTE: as of the live-refresh change, this value is also inlined into the
# client bundle (vite.config.ts `define`) so the browser can refresh data on
# each visit — i.e. it is PUBLICLY visible to site visitors. The CR token is
# read-only and allowlisted to the RoyaleAPI proxy IP, so the blast radius is
# rate-limit abuse only; rotate it at developer.clashroyale.com if abused.
CR_API_TOKEN=

# Your clan tag, including the leading #, e.g. #2P0LYQ
# MUST be quoted — an unquoted leading # is parsed as a comment and dropped.
CLAN_TAG="#PLACEHOLDER"

# API base URL. The RoyaleAPI proxy lets the token work from any IP
# (Supercell ties raw tokens to allowlisted IPs, which breaks in CI).
# Allowlist the proxy IP 45.79.218.79 when you create the token.
# To call Supercell directly instead, use https://api.clashroyale.com/v1
CR_API_BASE=https://proxy.royaleapi.dev/v1
